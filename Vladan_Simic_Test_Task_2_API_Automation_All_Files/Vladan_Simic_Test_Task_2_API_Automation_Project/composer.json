{
  "name": "vladan-simic/media-buyers-api-tests",
  "description": "PHP Codeception API automation solution for the Media Buyers API contract.",
  "type": "project",
  "require-dev": {
    "codeception/codeception": "^5.1",
    "codeception/module-asserts": "^3.0",
    "codeception/module-phpbrowser": "^3.0",
    "codeception/module-rest": "^3.4",
    "justinrainbow/json-schema": "^6.0",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\Support\\": "tests/_support/"
    }
  },
  "scripts": {
    "test:api": "codecept run Api --steps",
    "test:api:ci": "codecept run Api --xml --html"
  }
}

